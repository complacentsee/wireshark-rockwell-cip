# No pcaps in this repository, full stop. Live capture material stays
# out of source control even when sanitised — tests regenerate any
# needed inputs locally via tools/extract_fixture.py against a developer-
# owned pcap, and the fixture files live outside the repo tree.
*.pcap
*.pcapng

# Python / pytest scratch
__pycache__/
*.pyc
.pytest_cache/
.tox/
.venv/
venv/

# Wireshark / tshark scratch output
*.pdml.actual
*.pdml.diff

# Out-of-tree C build output
proto-c/build/
proto-c/*.o
proto-c/*.so
proto-c/*.dylib

# Editor / OS noise
.DS_Store
.idea/
.vscode/
*.swp
